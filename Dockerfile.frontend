FROM node:20-slim AS builder

WORKDIR /app
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci

COPY frontend/ .
RUN npm run build

FROM node:20-slim
WORKDIR /app
COPY --from=builder /app/build ./build
COPY --from=builder /app/package.json .
RUN npm ci --omit=dev

EXPOSE 5173
ENV PORT=5173
ENV HOST=0.0.0.0

CMD ["node", "build"]
