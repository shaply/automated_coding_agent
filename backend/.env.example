# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.

# AutoDev API authentication — set a long random string
AUTODEV_API_TOKEN=change-me-to-a-long-random-secret

# LLM provider API keys
ANTHROPIC_API_KEY=your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=your-groq-key-here

# GitHub integration (required for Phase 5+)
GITHUB_TOKEN=your-github-pat-here

# Data directory (default: /data in Docker, ./data locally)
AUTODEV_DATA_DIR=./data
