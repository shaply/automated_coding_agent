# Copy this to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.

# Localhost when running locally, or the IP address of the server when running in production.
# Basically, if you're running the backend on another machine and the frontend is set to localhost,
# when you pull the frontend code and run it, it won't be able to connect to the backend. So you need to set this to the IP address of the machine running the backend.
VITE_API_URL=http://localhost:8094
VITE_API_TOKEN=change-me-to-match-AUTODEV_API_TOKEN
